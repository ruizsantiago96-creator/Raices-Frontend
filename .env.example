# ─── Firebase REST API Key (pública) ────────────────────────────────
# Web API Key de tu proyecto Firebase:
#   Firebase Console → ⚙️ Configuración del proyecto → General → Web API Key
#
# Se usa únicamente para el puente de autenticación cuando el login del
# backend devuelve 401. Se contacta directamente la REST API de Firebase
# SIN instalar el SDK.
VITE_FIREBASE_API_KEY=TU_API_KEY_DE_FIREBASE
